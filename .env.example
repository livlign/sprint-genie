# ─── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Jira ─────────────────────────────────────────────────────────────────────
# Your Atlassian account email
JIRA_EMAIL=you@yourcompany.com

# Jira API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token

# Your Jira instance base URL (no trailing slash)
JIRA_BASE_URL=https://yourcompany.atlassian.net

# ─── Source code browsing ─────────────────────────────────────────────────────
# Absolute path to the project root you want Claude to browse during grooming
# Leave blank to disable code browsing
PROJECT_ROOT=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
